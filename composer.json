{
    "name": "larasofthu/laravel-guardian",
    "version": "1.0.3",
    "description": "Laravel package for file integrity checking against Git state",
    "keywords": [
        "laravel",
        "guardian",
        "file-integrity",
        "git"
    ],
    "license": "MIT",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Larasofthu\\LaravelGuardian\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Kapási Fülöp",
            "email": "fulopkapasi@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.91.1",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Larasofthu\\LaravelGuardian\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larasofthu\\LaravelGuardian\\FileIntegrityServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
